# BabelDOC Web 环境配置
# 复制此文件为 .env 并修改配置

# 数据库连接
DATABASE_URL=postgresql+asyncpg://babeldoc:babeldoc@localhost:5432/babeldoc

# 安全密钥（务必修改为随机字符串）
SECRET_KEY=change-me-in-production-use-a-long-random-string

# JWT Token 有效期（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 翻译队列配置
MAX_CONCURRENT_TRANSLATIONS=2
MAX_QUEUE_SIZE=100

# 翻译设置
DEFAULT_QPS=4

# BabelDOC 离线模式
# 启用后，后端不会在翻译过程中尝试联网拉取 BabelDOC 资产；
# 如果本地资产不完整，会直接报明确错误
BABELDOC_OFFLINE_MODE=false

# 可选：指定一个离线资产包 zip，后端启动时会自动恢复到本地缓存
# 例如：/data/babeldoc/offline_assets_xxx.zip
BABELDOC_OFFLINE_ASSETS_PACKAGE=

# 可选：启动时主动检查当前 profile 下的 BabelDOC 资产是否完整
BABELDOC_PRECHECK_ASSETS_ON_STARTUP=false

# 可选：离线资产检查范围
# full: 检查全部资产，最严格
# core: 仅检查 models/fonts/tiktoken，适合更轻量的离线预检
# minimal: 仅检查 models/tiktoken，适合最小化启动前校验
# 建议：生产离线部署使用 full，开发环境可用 core，最小预检用 minimal
BABELDOC_OFFLINE_ASSET_PROFILE=full

# 可选：管理员页面“预热并导出离线包”默认输出目录
BABELDOC_OFFLINE_EXPORT_DIR=app/outputs/offline-assets
