# BabelDOC Web 环境配置
# 复制此文件为 .env 并修改配置

# 数据库连接
DATABASE_URL=postgresql+asyncpg://babeldoc:babeldoc@localhost:5432/babeldoc

# 安全密钥（务必修改为随机字符串）
SECRET_KEY=change-me-in-production-use-a-long-random-string

# JWT Token 有效期（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 翻译队列配置
MAX_CONCURRENT_TRANSLATIONS=2
MAX_QUEUE_SIZE=100

# 默认翻译设置
DEFAULT_QPS=4
DEFAULT_MODEL=gpt-4o-mini

# OpenAI API Key（如果用户未配置自定义模型时使用）
OPENAI_API_KEY=sk-your-key-here
